# Used by `npm run build:mac` for code-signing + notarization.
# Copy to .env and fill in real values. NEVER commit .env.

# Path to the Developer ID Application .p12 export from Keychain Access.
# Leave blank to fall back to whatever cert is in the local Keychain
# (electron-builder auto-discovery).
CSC_LINK=
CSC_KEY_PASSWORD=

# App Store Connect API key for notarization.
APPLE_API_KEY=/Users/chrislanzilli/Downloads/AuthKey_28FNDQ3332.p8
APPLE_API_KEY_ID=28FNDQ3332
APPLE_API_ISSUER=

# Apple Developer Team ID (Christopher Lanzilli individual)
APPLE_TEAM_ID=L78CXLCJLX
